# ============================================
# NOIRAX — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe (required for payments - LIVE) ---
# Use live keys for production, test keys for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_live_your-webhook-secret

# --- AI Provider (required for signal explanations) ---
# Primary: gemini (free tier). Set AI_PROVIDER=gemini
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
# Alternative: CLAUDE_API_KEY=your-claude-api-key

# --- Affiliate Links (configurable without redeploy) ---
AFFILIATE_BINANCE=https://accounts.binance.com/en/register?ref=YOUR_REF
AFFILIATE_BYBIT=https://www.bybit.com/en/sign-up?ref=YOUR_REF
AFFILIATE_KRAKEN=https://www.kraken.com/sign-up?ref=YOUR_REF

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://noirax-plum.vercel.app
SIGNALS_CRON_INTERVAL_MINUTES=10
SIGNALS_MIN_VOLUME_24H_USD=1000000

# --- Proprietary Pipeline Parameters (tune via GitHub Secrets) ---
TECH_TOP_COINS_FREE=15
TECH_RSI_OVERSOLD=35
TECH_RSI_OVERBOUGHT=65
TECH_CONFIDENCE_RSI=20
TECH_CONFIDENCE_MACD=15
TECH_CONFIDENCE_SMA=15
TECH_CONFIDENCE_VOLUME=10
TECH_CONFIDENCE_SUPPORT=15
TECH_CONFIDENCE_RESISTANCE=10
TECH_VOLUME_SPIKE_MULTIPLIER=1.5
TECH_NEAR_SUPPORT_OFFSET=1.05
TECH_NEAR_RESISTANCE_OFFSET=0.95
TECH_RISK_HIGH_THRESHOLD=0.05
TECH_RISK_MEDIUM_THRESHOLD=0.03
TECH_ATR_SL_CONSERVATIVE=1.5
TECH_ATR_TP1_CONSERVATIVE=2.0
TECH_ATR_SL_OPTIMIZED=2.0
TECH_ATR_TP1_OPTIMIZED=2.0
TECH_ATR_TP2_OPTIMIZED=3.5
TECH_ATR_TP3_OPTIMIZED=5.0
FUND_WHALE_THRESHOLD_BTC=20.0
FUND_FUNDING_RATE_HIGH=0.0005
FUND_FUNDING_RATE_LOW=-0.0005
FUND_FUNDING_RATE_ELEVATED=0.0002
FUND_VOLUME_QUOTE_THRESHOLD=50000000
FUND_VOLUME_PRICE_CHANGE_PCT=5.0
FUND_VOLUME_ELEVATED_CHANGE_PCT=2.0
FUND_SCORE_CLAMP_HIGH=3
FUND_SCORE_CLAMP_MEDIUM=1
FUND_SCORE_CLAMP_NEG_HIGH=-3
FUND_SCORE_CLAMP_NEG_MEDIUM=-1
FUND_NEWS_BULL_MIN_COUNT=2
