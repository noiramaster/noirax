# ============================================
# NOIRAX — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Stripe (required for payments - LIVE) ---
# Use live keys for production, test keys for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your-publishable-key
STRIPE_SECRET_KEY=sk_live_your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_live_your-webhook-secret

# --- AI Provider (required for signal explanations) ---
# Primary: gemini (free tier). Set AI_PROVIDER=gemini
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
# Alternative: CLAUDE_API_KEY=your-claude-api-key

# --- Affiliate Links (configurable without redeploy) ---
AFFILIATE_BINANCE=https://accounts.binance.com/en/register?ref=YOUR_REF
AFFILIATE_BYBIT=https://www.bybit.com/en/sign-up?ref=YOUR_REF
AFFILIATE_KRAKEN=https://www.kraken.com/sign-up?ref=YOUR_REF

# --- App Config ---
NEXT_PUBLIC_APP_URL=https://noirax-plum.vercel.app
SIGNALS_CRON_INTERVAL_MINUTES=10
SIGNALS_MIN_VOLUME_24H_USD=1000000

# --- Proprietary Pipeline Parameters (tune via GitHub Variables/Secrets) ---
# Defaults in code are placeholder values. Set these via GitHub Variables
# or Vercel env vars to override.
TECH_TOP_COINS_FREE=0
TECH_RSI_OVERSOLD=0
TECH_RSI_OVERBOUGHT=100
TECH_CONFIDENCE_RSI=0
TECH_CONFIDENCE_MACD=0
TECH_CONFIDENCE_SMA=0
TECH_CONFIDENCE_VOLUME=0
TECH_CONFIDENCE_SUPPORT=0
TECH_CONFIDENCE_RESISTANCE=0
TECH_VOLUME_SPIKE_MULTIPLIER=999.0
TECH_NEAR_SUPPORT_OFFSET=0.5
TECH_NEAR_RESISTANCE_OFFSET=1.5
TECH_RISK_HIGH_THRESHOLD=1.0
TECH_RISK_MEDIUM_THRESHOLD=0.5
TECH_ATR_SL_CONSERVATIVE=1.0
TECH_ATR_TP1_CONSERVATIVE=1.0
TECH_ATR_SL_OPTIMIZED=1.0
TECH_ATR_TP1_OPTIMIZED=1.0
TECH_ATR_TP2_OPTIMIZED=1.0
TECH_ATR_TP3_OPTIMIZED=1.0
FUND_WHALE_THRESHOLD_BTC=999.0
FUND_FUNDING_RATE_HIGH=0.5
FUND_FUNDING_RATE_LOW=-0.5
FUND_FUNDING_RATE_ELEVATED=0.1
FUND_VOLUME_QUOTE_THRESHOLD=999999999
FUND_VOLUME_PRICE_CHANGE_PCT=100.0
FUND_VOLUME_ELEVATED_CHANGE_PCT=50.0
FUND_SCORE_CLAMP_HIGH=10
FUND_SCORE_CLAMP_MEDIUM=5
FUND_SCORE_CLAMP_NEG_HIGH=-10
FUND_SCORE_CLAMP_NEG_MEDIUM=-5
FUND_NEWS_BULL_MIN_COUNT=99
